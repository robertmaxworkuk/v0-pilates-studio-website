# Sentry — copy to .env and fill in your values
# Get DSN at: Sentry → Settings → Projects → <your project> → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.de.sentry.io/<project-id>
SENTRY_DSN=https://<key>@<org>.ingest.de.sentry.io/<project-id>

# Source Maps upload — get at: sentry.io/settings/auth-tokens/
# Requires scopes: project:releases, org:read
# SENTRY_AUTH_TOKEN=sntrys_eyJ...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
